{
  "name": "piggybank-extension",
  "version": "1.0.0",
  "description": "A Bitcoin piggy bank for children",
  "main": "background.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "watch": "webpack --watch --config webpack.config.js",
    "package": "zip -r piggybank-extension.zip . -x \"node_modules/*\" -x \".git/*\" -x \"src/*\" -x \"package-lock.json\""
